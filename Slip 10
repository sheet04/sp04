2) Write a Python program to count the number of strings where the string 
length is 3 or more and the first and last character are same from a given list of 
strings. 

def count_strings(words):
 count = 0
 
 for word in words:
 if len(word) >= 3 and word[0] == word[-1]:
 count += 1
 
 return count
string_list = ['abc', 'xyz', 'aba', '1221', 'aa', 'level']
result = count_strings(string_list)
print("Number of matching strings:", result)
