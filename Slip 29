Q2. Write Grade System Macro

Sub GradeSystem()
Dim m As Integer
m = Range("A1").Value
If m >= 90 Then
MsgBox "Grade: A+"
ElseIf m >= 75 Then
MsgBox "Grade: A"
ElseIf m >= 60 Then
MsgBox "Grade: B"
ElseIf m >= 40 Then
MsgBox "Grade: C"
Else
MsgBox "Fail"
End If
End Sub

