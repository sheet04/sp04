2) Write a Python function that accepts a string and calculate the number of 
vowels and consonants of a string and display them.

def count_vowels_consonants(text):
 vowels = "aeiouAEIOU"
 v_count = 0
 c_count = 0
 for ch in text:
 if ch.isalpha(): 
 if ch in vowels:
 v_count += 1
 else:
 c_count += 1
 print("Number of vowels:", v_count)
 print("Number of consonants:", c_count)
 string = input("Enter a string: ")
count_vowels_consonants(string)

